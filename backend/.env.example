# 服务
PORT=8080
ENV=development

# JWT（生产环境务必更换）
JWT_SECRET=dev-change-me-in-production

# 逗号分隔；与 integration-plan.md §6 一致
# 生产域名可省略（同源请求会自动放行）；跨域前后端分离时须加入前端 Origin
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# 演示账号（仅 DB 不可用时 Client / Admin 登录回退）
CLIENT_DEMO_ACCOUNT=vs8888
CLIENT_DEMO_PASSWORD=vs8888
ADMIN_DEMO_ACCOUNT=admin
ADMIN_DEMO_PASSWORD=admin123

# Access Token 有效期（小时）
TOKEN_TTL_HOURS=8

# PostgreSQL 18（远程或本地）
# 方式一：完整 DSN
# DATABASE_URL=postgres://caipiaoapp:YOUR_PASSWORD@192.168.100.239:5432/caipiao?sslmode=disable
# 方式二：拆分变量（未设 DATABASE_URL 时生效）
DB_HOST=192.168.100.239
DB_PORT=5432
DB_NAME=caipiao
DB_USER=caipiaoapp
DB_PASSWORD=YOUR_PASSWORD
DB_SSLMODE=disable

# 启动时是否必须连上数据库（true=连不上则退出；false=降级为内存 Store）
DB_REQUIRED=true

# pgx 连接池（高并发可调大；HTTP 与后台 Worker 共用此池）
DB_MAX_CONNS=25
DB_MIN_CONNS=2

# 后台 Worker（方案实例结算 + pending 投注订单开奖结算；共用 lottery_draws）
SCHEME_WORKER_ENABLED=true
SCHEME_WORKER_TICK_SEC=5

# WebSocket（WS-1：维护开关推送）
WS_ENABLED=true
WS_AUTH_VIA_QUERY=true

# 第三方挂机平台 Guaji（T0）
# 默认对接 https://www.v6hs1.com（彩种/玩法 outbound 见迁移 00110/00111）
GUAJI_ENABLED=false
GUAJI_HTTP_BASE=https://www.v6hs1.com
GUAJI_AUTH_BASE=https://www.v6hs1.com
GUAJI_WS_BASE=wss://www.v6hs1.com
# 开奖 WS 路径（实测端点为 /ws，非文档的 /?token=）
GUAJI_WS_PATH=/ws
GUAJI_ORIGIN=https://www.v6hs1.com
GUAJI_IS_AI=true
GUAJI_HTTP_TIMEOUT_SEC=30
# T1 绑号凭证加密（32 字节，hex 或 base64）
# GUAJI_CREDENTIALS_KEY=
# 连通性 smoke（cmd/guaji-smoke / GET /health guaji 块）
# 测试账号（接口文档 §12）：testcq01~testcq10，密码同账号名；资金密码/密保 147258
# GUAJI_TEST_USERNAME=testcq01
# GUAJI_TEST_PASSWORD=testcq01

# CMS 富文本图片上传目录（相对 backend 工作目录）
CMS_UPLOAD_DIR=./data/uploads/cms
