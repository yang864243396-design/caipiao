# 后端 REST 基址（联调时必填）
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1
# 演示数据来自后端 PostgreSQL seed（migrate 后可用）
# WebSocket（可选；默认由 API_BASE 推导 ws://.../api/v1/ws/admin）
# VITE_WS_ADMIN_URL=ws://127.0.0.1:8080/api/v1/ws/admin
VITE_WS_ENABLED=true
# P5 彩种维护编辑（P1 默认只读，不设或 false）
# VITE_LOTTERY_CATALOG_P5=true
