# 后端 REST 基址（联调示例）

VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1

# 演示数据：在后端执行 migrate 后由 PostgreSQL seed 提供

# WebSocket（可选；默认由 API_BASE 或生产同源 origin 推导）
# 生产 HTTPS 须用 wss://；也可只配 VITE_API_BASE_URL，由代码自动转为 wss
# VITE_WS_PUBLIC_URL=wss://your-domain.com/api/v1/ws/public
# VITE_WS_CLIENT_URL=wss://your-domain.com/api/v1/ws/client
VITE_WS_ENABLED=true

